{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"files": {
		"includes": [
			"**",
			"!!**/coverage",
			"!!**/.next",
			"!!**/dist",
			"!!**/build",
			"!!**/out",
			"!!apps/web/eslint.json"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noStaticOnlyClass": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["apps/api/src/tests/**", "apps/api/tests/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["sample/**"],
			"linter": {
				"rules": {
					"complexity": {
						"noStaticOnlyClass": "off",
						"noUselessConstructor": "off"
					},
					"correctness": {
						"noUnusedVariables": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/web/src/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useFocusableInteractive": "off"
					},
					"performance": {
						"noImgElement": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/web/src/app/layout.tsx"],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		}
	]
}
