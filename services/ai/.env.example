# Sentence-Transformers model — do not change, must stay 384-dim
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: cache downloaded model weights locally
# MODEL_CACHE_DIR=./models

# ── Gemini API (required for hybrid classification) ───────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Used by the classification layer for gibberish detection and language quality assessment.
# If not set, the system falls back to scikit-learn only (no authenticity check).
GEMINI_API_KEY=your-gemini-api-key-here

# ── MongoDB Atlas Vector Search (set up when ready) ──────────────────────────
# The AI service does NOT write to MongoDB — the Node backend does.
# When you are ready, create a vector search index in Atlas UI:
#
#   Database   : sepms
#   Collection : embeddingentries
#   Index name : vector_index
#   Definition :
#     {
#       "fields": [{
#         "type": "vector",
#         "path": "vector",
#         "numDimensions": 384,
#         "similarity": "cosine"
#       }]
#     }
